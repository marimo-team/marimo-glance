{
  "name": "marimo-glance",
  "description": "Render marimo notebooks inline on GitHub and gists instead of raw Python source.",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "compile": "turbo run compile",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "oxlint": "^1.74.0",
    "turbo": "^2.6.3",
    "typescript": "^7.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
